# CineMatch Environment Variables Template
# Copy this file to .env and fill in your keys

# The Movie Database (TMDB) API Key (Required for Posters, Cast, and Trailers)
# Get a free key at: https://www.themoviedb.org/settings/api
TMDB_API_KEY=your_tmdb_api_key_here

# AI Companion API Keys (Provide at least one of these to enable the AI assistant)
# Groq API Key (Preferred) - Get it at: https://console.groq.com/
GROQ_API_KEY=your_groq_api_key_here

# Gemini API Key (Alternative) - Get it at: https://aistudio.google.com/
GEMINI_API_KEY=your_gemini_api_key_here

# OpenAI API Key (Alternative) - Get it at: https://platform.openai.com/
OPENAI_API_KEY=your_openai_api_key_here

# Selected LLM Provider: 'groq', 'gemini', or 'openai' (default is 'groq')
LLM_PROVIDER=groq
